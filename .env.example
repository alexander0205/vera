# ─── Base de datos (Neon, Supabase o cualquier Postgres) ─────────────────────
# Nota: debe ser .env (no .env.local) para que drizzle-kit lo encuentre
POSTGRES_URL=postgresql://user:password@host:5432/emitedo

# ─── Auth (JWT session — el starter maneja esto internamente) ─────────────────
# Genera un secreto aleatorio: openssl rand -base64 32
AUTH_SECRET=cambia-esto-por-un-secreto-aleatorio-largo

# ─── Stripe (pagos y suscripciones) ──────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Price IDs — obtener desde el Stripe Dashboard (Products > Prices)
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_INVOICE=price_...
STRIPE_PRICE_BUSINESS=price_...
STRIPE_PRICE_PRO=price_...

# ─── App ──────────────────────────────────────────────────────────────────────
BASE_URL=http://localhost:3000

# ─── DGII (ambiente por defecto) ─────────────────────────────────────────────
# Valores: TesteCF | CerteCF | eCF
DGII_ENVIRONMENT=TesteCF

# ─── Cifrado de certificados (AES-256-GCM) ────────────────────────────────────
# Genera UNA SOLA VEZ y nunca cambies (o perderás acceso a todos los certs):
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Agregar también en Vercel Dashboard → Settings → Environment Variables
CERT_MASTER_KEY=
